<?xml version="1.0"?>
<robot name="tricycle_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- ==================== 宏定义 ==================== -->
    <xacro:property name="PI" value="3.1415926535" />
    <xacro:include filename="$(find robot_description)/urdf/common_property.xacro" />
    <xacro:include filename="$(find robot_description)/urdf/mobile.xacro" />
</robot>