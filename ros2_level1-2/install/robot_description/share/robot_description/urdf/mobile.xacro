<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- 轮子宏 -->
    <xacro:macro name="wheel_with_tire" params="name prefix x y z">
        <!-- 轮毂 -->
        <link name="${prefix}_${name}_wheel_link">
            <visual>
                <geometry><cylinder length="0.06" radius="0.10"/></geometry>
                <origin xyz="0 0 0" rpy="0 ${PI/2} 0"/>
                <material name="wheel_black"/>


            </visual>
            <collision>
                <geometry><cylinder length="0.06" radius="0.10"/></geometry>
                <origin xyz="0 0 0" rpy="0 ${PI/2} 0"/>
            </collision>
            <inertial>
                <mass value="0.08"/>
                <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
            </inertial>
        </link>

        <!-- 轮胎（稍大一圈） -->
        <link name="${prefix}_${name}_tire_link">
            <visual>
                <geometry><cylinder length="0.08" radius="0.13"/></geometry>
                <origin xyz="0 0 0" rpy="0 ${PI/2} 0"/>
                <material name="tire_dark"/>
            </visual>
            <collision>
                <geometry><cylinder length="0.08" radius="0.13"/></geometry>
                <origin xyz="0 0 0" rpy="0 ${PI/2} 0"/>
            </collision>
            <inertial>
                <mass value="0.05"/>
                <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0003"/>
            </inertial>
        </link>

       
        <joint name="${prefix}_${name}_tire_joint" type="fixed">
            <parent link="${prefix}_${name}_wheel_link"/>
            <child link="${prefix}_${name}_tire_link"/>
            <origin xyz="0 0 0"/>
        </joint>

      
        <joint name="${prefix}_${name}_wheel_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${prefix}_${name}_wheel_link"/>
            <origin xyz="${x} ${y} ${z}" rpy="0 ${PI/2} 0"/>
            <axis xyz="0 1 0"/>
        </joint>
    </xacro:macro>

    
    <link name="base_footprint">
        <visual>
            <geometry><box size="0.01 0.01 0.01"/></geometry>
            <origin xyz="0 0 0"/>
            <material name="connector_pink"/>
        </visual>
    </link>

    <joint name="footprint_to_base" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.12"/>
    </joint>

  
    <link name="base_link">
        <visual>
            <geometry><box size="0.50 0.35 0.12"/></geometry>
            <origin xyz="0 0 0"/>
            <material name="body_red"/>
        </visual>
        <collision>
            <geometry><box size="0.50 0.35 0.12"/></geometry>
            <origin xyz="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.8"/>
            <inertia ixx="0.08" ixy="0" ixz="0" iyy="0.06" iyz="0" izz="0.05"/>
        </inertial>
    </link>

    <!-- ==================== 车身 — 上层盖板（红色，略小） ==================== -->
    <link name="top_plate_link">
        <visual>
            <geometry><box size="0.40 0.25 0.04"/></geometry>
            <origin xyz="0 0 0"/>
            <material name="body_red"/>
        </visual>
        <collision>
            <geometry><box size="0.40 0.25 0.04"/></geometry>
            <origin xyz="0 0 0"/>
        </collision>
        <inertial>
            <mass value="0.2"/>
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
        </inertial>
    </link>

    <joint name="top_plate_joint" type="fixed">
        <parent link="base_link"/>
        <child link="top_plate_link"/>
        <origin xyz="0 0 0.08"/>
    </joint>

    <!-- ==================== 粉色连接件 — 左后 ==================== -->
    <link name="rear_left_connector_link">
        <visual>
            <geometry><box size="0.06 0.06 0.06"/></geometry>
            <origin xyz="0 0 0"/>
            <material name="connector_pink"/>
        </visual>
    </link>
    <joint name="rear_left_connector_joint" type="fixed">
        <parent link="base_link"/>
        <child link="rear_left_connector_link"/>
        <origin xyz="-0.20 -0.18 -0.06"/>
    </joint>

    <!-- ==================== 粉色连接件 — 右后 ==================== -->
    <link name="rear_right_connector_link">
        <visual>
            <geometry><box size="0.06 0.06 0.06"/></geometry>
            <origin xyz="0 0 0"/>
            <material name="connector_pink"/>
        </visual>
    </link>
    <joint name="rear_right_connector_joint" type="fixed">
        <parent link="base_link"/>
        <child link="rear_right_connector_link"/>
        <origin xyz="-0.20 0.18 -0.06"/>
    </joint>

    <!-- ==================== 粉色连接件 — 前 ==================== -->
    <link name="front_connector_link">
        <visual>
            <geometry><box size="0.06 0.06 0.06"/></geometry>
            <origin xyz="0 0 0"/>
            <material name="connector_pink"/>
        </visual>
    </link>
    <joint name="front_connector_joint" type="fixed">
        <parent link="base_link"/>
        <child link="front_connector_link"/>
        <origin xyz="0.25 0 -0.06"/>
    </joint>

    <!-- ==================== 车轮（使用宏生成） ==================== -->
    <xacro:wheel_with_tire name="left_rear"  prefix="rr" x="-0.20" y="-0.22" z="-0.06"/>
    <xacro:wheel_with_tire name="right_rear" prefix="rr" x="-0.20" y=" 0.22" z="-0.06"/>
    <xacro:wheel_with_tire name="front"      prefix="fr" x=" 0.25" y=" 0.00" z="-0.06"/>

</robot>
